# --- PIK-R CONFIGURATION ---

# API Key untuk mengamankan REST API (bisa diganti untuk keamanan tambahan)
PIKR_API_KEY=pikr-admin-secret-2024

# URL Database Supabase (PostgreSQL online)
# Format: postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres
# Kosongkan jika ingin tetap menggunakan SQLite lokal (database/pikr.db)
SUPABASE_DB_URL=

# Kredensial sinkronisasi Google Sheets
# Path ke file JSON kredensial Google Service Account yang diunduh dari Google Cloud Console
GOOGLE_CREDS_PATH=credentials.json

# Nama Dokumen Google Spreadsheet tempat data disinkronkan
GOOGLE_SHEET_NAME=PIK-R Database

# Email Anda/Klien untuk dibagikan akses otomatis ke Google Sheets yang dibuat (Opsional)
# SHARE_GOOGLE_SHEET_WITH=email-anda@gmail.com
